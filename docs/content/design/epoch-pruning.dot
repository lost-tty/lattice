digraph epoch_pruning {
    rankdir=TB;
    fontname="Helvetica";
    fontsize=14;
    label="Epoch pruning: snapshot is computed locally, not embedded in the DAG";
    labelloc=t;
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", width=2.4, height=0.4];
    edge [fontname="Helvetica", fontsize=8];

    // ═══════════════════════════════════════════════════════════════
    // Phase 1: Full DAG before pruning
    // ═══════════════════════════════════════════════════════════════

    subgraph cluster_before {
        label="Before pruning (epoch 1 settled)";
        labeljust=l;
        fontsize=12;
        fontname="Helvetica-Bold";
        style="dashed";
        color="#666666";
        margin=16;

        p1_genesis  [label="genesis", fillcolor="#e8e8e8"];
        p1_sys      [label="A: add_peer A,B,C\nset_name, set_strategy\ndeps: [genesis]", fillcolor="#b3d9ff"];
        p1_epoch0   [label="epoch 0\ndeps: [genesis, A:sys_batch]", fillcolor="#ffeeaa", penwidth=2];

        p1_bputx1   [label="B: put x = 1\ndeps: [epoch 0]", fillcolor="#c2f0c2"];
        p1_cputy1   [label="C: put y = 10\ndeps: [epoch 0]", fillcolor="#d9b3ff"];
        p1_bputx2   [label="B: put x = 2\ndeps: [B:put x=1]", fillcolor="#c2f0c2"];
        p1_cputy2   [label="C: put y = 20\ndeps: [C:put y=10]", fillcolor="#d9b3ff"];

        p1_revoke   [label="A: revoke_peer C\ndeps: [A:sys_batch]", fillcolor="#ffb3b3"];
        p1_epoch1   [label="epoch 1\nrequired_acks: [B]\ndeps: [genesis,\n          A:revoke_peer C,\n          B:put x=2,\n          C:put y=20]", fillcolor="#ffeeaa", penwidth=2];

        p1_back     [label="B: epoch_ack\ndeps: [B:put x=2, epoch 1]", fillcolor="#ffe0b2", penwidth=2];
        p1_bputx3   [label="B: put x = 3\ndeps: [B:epoch_ack]", fillcolor="#c2f0c2"];

        // Edges
        p1_genesis -> p1_sys;
        p1_genesis -> p1_epoch0;
        p1_sys     -> p1_epoch0;
        p1_epoch0  -> p1_bputx1;
        p1_epoch0  -> p1_cputy1;
        p1_bputx1  -> p1_bputx2;
        p1_cputy1  -> p1_cputy2;
        p1_sys     -> p1_revoke;
        p1_genesis -> p1_epoch1;
        p1_revoke  -> p1_epoch1;
        p1_bputx2  -> p1_epoch1;
        p1_cputy2  -> p1_epoch1;
        p1_bputx2  -> p1_back;
        p1_epoch1  -> p1_back;
        p1_back    -> p1_bputx3;

        // State
        node [shape=box, fillcolor="#f5f5f5", style="rounded,filled", fontsize=9, width=3.4];
        p1_s [label="State: peers={A,B} epoch=1 x=3 y=20\nEpoch 1 settled (B acked).\nEach node computes snapshot locally\nfrom epoch 1's frontier."];
        p1_bputx3 -> p1_s [style=dotted, color="#999999"];
    }

    // ═══════════════════════════════════════════════════════════════
    // Phase 2: After full pruning — minimal DAG
    // ═══════════════════════════════════════════════════════════════

    subgraph cluster_after {
        label="After full pruning (all acks in, frontier tips pruned)";
        labeljust=l;
        fontsize=12;
        fontname="Helvetica-Bold";
        style="dashed";
        color="#333333";
        margin=16;

        p2_genesis  [label="genesis", fillcolor="#e8e8e8"];
        p2_epoch1   [label="epoch 1\nrequired_acks: [B]", fillcolor="#ffeeaa", penwidth=2];
        p2_back     [label="B: epoch_ack", fillcolor="#ffe0b2", penwidth=2];
        p2_bputx3   [label="B: put x = 3", fillcolor="#c2f0c2"];

        p2_pruned   [label="PRUNED:\nepoch 0, add_peer, revoke_peer,\nB:put x=1, x=2, C:put y=10, y=20", fillcolor="#ffffff", style="rounded,dashed", fontcolor="#bbbbbb", color="#bbbbbb"];

        p2_genesis  -> p2_epoch1;
        p2_epoch1   -> p2_back;
        p2_back     -> p2_bputx3;
        p2_genesis  -> p2_pruned [style=dashed, color="#bbbbbb"];
        p2_pruned   -> p2_epoch1 [style=dashed, color="#bbbbbb"];

        node [shape=box, fillcolor="#f5f5f5", style="rounded,filled", fontsize=9, width=3.4];
        p2_s [label="Minimal log: genesis + epoch 1 + tail.\nEpoch 1's causal_deps still reference the\npruned frontier tips by hash — but no node\nneeds to resolve them. The state was\ncomputed and stored locally before pruning."];
        p2_bputx3 -> p2_s [style=dotted, color="#999999"];
    }

    // ═══════════════════════════════════════════════════════════════
    // Phase 3: Bootstrap from pruned store
    // ═══════════════════════════════════════════════════════════════

    subgraph cluster_bootstrap {
        label="Bootstrapping a new peer from a pruned store";
        labeljust=l;
        fontsize=12;
        fontname="Helvetica-Bold";
        style="dashed";
        color="#006600";
        margin=16;

        node [shape=box, fillcolor="#e8f5e9", style="rounded,filled", fontsize=9, width=4.0];

        b_step1 [label="1. New peer D joins via invite (genesis_hash in token)"];
        b_step2 [label="2. Bootstrap peer (A or B) sends:\n   a) genesis intention (verify identity)\n   b) epoch 1 intention (current epoch)\n   c) state snapshot at epoch 1 (computed locally)\n   d) tail: epoch_ack + B:put x=3"];
        b_step3 [label="3. D verifies: blake3(genesis) == genesis_hash from token"];
        b_step4 [label="4. D loads state snapshot:\n   system: peers={A:Active, B:Active, C:Revoked}\n           name=\"mystore\", strategy=Independent\n   data: x=2, y=20"];
        b_step5 [label="5. D projects tail on top of snapshot:\n   epoch_ack (no-op), B:put x=3 (x=2 -> x=3)\n   Result: peers={A,B} x=3 y=20"];
        b_step6 [label="6. D subscribes to epoch 1 gossip topic.\n   Ongoing sync via negentropy from epoch 1 forward."];

        b_step1 -> b_step2 -> b_step3 -> b_step4 -> b_step5 -> b_step6;

        node [shape=note, fillcolor="#ffffcc", style=filled, fontsize=9, width=4.0];
        b_note [label="The state snapshot is NOT in the epoch intention payload.\nIt is a local artifact, computed by projecting the epoch's\nfrontier before pruning. Transferred to new peers during\nbootstrap as a separate message. Each existing peer can\nserve the snapshot independently — they all computed the\nsame deterministic result from the same epoch frontier."];
        b_step6 -> b_note [style=invis];
    }
}
